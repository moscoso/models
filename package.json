        "@typescript-eslint/parser": "^8.59.0",
        "chai": "^6.2.2",
        "eslint": "^10.2.1",
        "mocha": "^11.7.5",
        "nyc": "^17.1.0",
        "rxjs": "^7.8.1",
        "ts-mocha": "^11.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
