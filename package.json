{
    "name": "@moscoso/models",
    "version": "0.0.2",
    "description": "Common Typescript interfaces and classes for models reused in all my games",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "scripts": {
        "build": "tsc",
        "compile": "tsc",
        "develop": "tsc -w",
        "lint": "eslint ./src/**",
